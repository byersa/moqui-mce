<?xml version="1.0" encoding="UTF-8"?>
<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/xml-screen-3.xsd"
        require-authentication="false" allow-extra-path="true" root-screen="true">

    <!-- Pre-Actions for Environment Setup -->
    <pre-actions>
        <!-- Identity Handshake -->
        <service-call name="mce.SessionServices.get#ConnectionToken" out-map="tokenOut" authenticate="false"/>
        <set field="connectionToken" from="tokenOut.connectionToken"/>
        <set field="isDesignMode" from="tokenOut.isDesignMode ?: 'N'"/>

        <!-- Bootstrapper for UI Assets and Dependencies -->
        <script location="component://moqui-mce/script/MceBootstrapper.groovy"/>

        <!-- Clear global script lists to prevent double-rendering by Moqui footer -->
        <script><![CDATA[
            context.put("local_html_stylesheets", new ArrayList(html_stylesheets))
            context.put("local_html_scripts", new ArrayList(html_scripts))
            context.put("local_footer_scripts", new ArrayList(footer_scripts))
            html_stylesheets.clear()
            html_scripts.clear()
            footer_scripts.clear()
        ]]></script>
    </pre-actions>

    <widgets>
        <render-mode>
            <text type="html"><![CDATA[
                <!-- WebMCP Configuration -->
                <script>
                    window.WEBMCP_SERVER = 'ws://localhost:3000';
                    window.WEBMCP_OPTIONS = { position: 'bottom-left', padding: '15px' };
                </script>
                
                <!-- CSS Injection from Bootstrapper -->
                <#list (local_html_stylesheets![]) as stylesheet>
                <link rel="stylesheet" href="${stylesheet}">
                </#list>

                <#-- AGGRESSIVE DEDUPLICATION: Track unique filenames to prevent double loads -->
                <#assign renderedBasenames = []>
                <#function isDuplicate url>
                    <#local basename = url?keep_before("?")?keep_after_last("/")>
                    <#if basename == ""> <#local basename = url> </#if>
                    <#if renderedBasenames?seq_contains(basename)>
                        <#return true>
                    <#else>
                        <#assign renderedBasenames = renderedBasenames + [basename]>
                        <#return false>
                    </#if>
                </#function>

                <!-- Head Scripts Injection -->
                <#list (local_html_scripts![]) as script>
                    <#if !isDuplicate(script)>
                        <script src="${script}"></script>
                    </#if>
                </#list>

                <!-- MCE2 Vue Mount Point -->
                <div id="q-app" v-cloak></div>
                
                <!-- JS Injection and Mounting -->
                <#list (local_footer_scripts![]) as script>
                    <#if !isDuplicate(script)>
                        <script src="${script}"></script>
                    </#if>
                </#list>

                <script type="module">
                    document.addEventListener('DOMContentLoaded', () => {
                        const initMce = () => {
                                console.info("MCE2 Shell: sessionToken: ${ec.web.sessionToken}");
                            if (window.Vue && window.Quasar && window.MceShell) {
                                if (window.MceShellInstance) return; 
                                
                                const { createApp } = window.Vue;
                                const app = createApp(window.MceShell, {
                                    connectionToken: '${connectionToken}',
                                    csrfToken: '${ec.web.sessionToken}',
                                    isDesignMode: '${isDesignMode}',
                                });
                                app.use(window.Quasar, {
                                    config: { dark: false, iconSet: 'material-icons-outlined' }
                                });
                                window.MceShellInstance = app.mount('#q-app');
                                console.info("MCE2 Shell: Production Foundation Initialized.");
                            } else {
                                setTimeout(initMce, 100);
                            }
                        };
                        initMce();
                    });
                </script>
            ]]></text>
        </render-mode>
    </widgets>
</screen>
